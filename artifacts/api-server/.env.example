# ─────────────────────────────────────────────────────────────────────────────
# Mythos api-server — environment variables
#
# Copy to `.env` for local overrides. On Replit, set these as Secrets instead of
# committing real values. Every variable here is OPTIONAL — the server runs
# without any of them, but email is only DELIVERED once a provider is configured.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode. In "production" the server never fakes email success: if no
# provider is configured (or a send fails), the form returns an honest error.
# In development, undelivered submissions are logged and simulated as success so
# local flows work without a provider.
NODE_ENV=production

# Port is assigned automatically by Replit; only set this for local runs.
# PORT=3000

# ── Where form submissions are emailed ──────────────────────────────────────
# Recipient of every inquiry. Defaults to info@mythosaisecurity.com.
CONTACT_EMAIL_TO=info@mythosaisecurity.com
# From address. Defaults to "Mythos AI Security <no-reply@mythosaisecurity.com>".
# The sending domain must be verified in Resend for real production delivery.
CONTACT_EMAIL_FROM=Mythos AI Security <no-reply@mythosaisecurity.com>

# ── Email provider ──────────────────────────────────────────────────────────
# Primary path on Replit: the Resend CONNECTION (Integrations → Resend). When
# connected, the server sends via @replit/connectors-sdk and no key is stored.
# REPLIT_CONNECTORS_HOSTNAME is provided automatically by the Replit runtime.
#
# Fallback for non-Replit hosting: a direct Resend API key. If set, it takes
# precedence over the connection.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ────────────────────────────────────────────────────────────────────
# The site and API are same-origin in dev and prod, so CORS is rarely needed.
# Replit *.replit.dev / *.replit.app / *.repl.co and localhost are allowed by
# default. Add your production site origin and any extra origins here.
# SITE_URL=https://mythosaisecurity.com
# ALLOWED_ORIGINS=https://www.mythosaisecurity.com,https://staging.example.com
